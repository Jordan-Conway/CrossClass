// Defines a public class called Person
version: 0.0.1

type: class

name: Person

visibility: public

equality: value

fields:
    field: 
        name: name
        type: string
        visibility: public
    field:
        name: age
        type: int32
        visibility: public
    field: 
        name: date_of_birth
        type: date
        visibility: private